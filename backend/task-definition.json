{
    "family": "hari-backend-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "backend",
            "image": "939213667098.dkr.ecr.ap-northeast-2.amazonaws.com/hari-backend:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                { "name": "DB_NAME", "value": "hari1-db" },
                { "name": "DB_USER", "value": "postgres_hari" },
                { "name": "DB_PORT", "value": "5432" },
                { "name": "DB_HOST", "value": "hari1-db.cfuwqwoao2pv.ap-northeast-2.rds.amazonaws.com" }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/hari-backend-task",
                    "awslogs-region": "ap-northeast-2",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "arn:aws:iam::939213667098:role/ecsTaskExecutionRole"
}
